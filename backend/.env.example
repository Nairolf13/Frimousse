# Copy this file to `.env` in production and fill the secret values.
# Do NOT commit real secrets to git.

# --- App & env
NODE_ENV=production
PORT=4000
TRUST_PROXY=true

# --- JWT secrets
JWT_SECRET=your_jwt_secret_here
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here

# --- Stripe
STRIPE_SECRET_KEY=sk_test_xxx_replace_with_real

# --- Database (Prisma) - example for Postgres
DATABASE_URL=postgresql://user:password@host:5432/dbname?schema=public

# --- Redis (for rate limiter and shared cache)
# If Redis is local with no password: redis://127.0.0.1:6379
# If Redis requires auth: redis://:PASSWORD@host:6379
REDIS_URL=redis://127.0.0.1:6379

# --- Rate limit tuning
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=10

# --- Upload limits
UPLOAD_MAX_BYTES=10485760  # 10MB

# --- JSON body limit for express
EXPRESS_JSON_LIMIT=100kb

# --- Cache TTLs
CENTERS_CACHE_TTL_MS=30000

# --- Optional Sentry
#SENTRY_DSN=

# --- SMTP for transactional email (optional)
#SMTP_HOST=
#SMTP_PORT=
#SMTP_USER=
#SMTP_PASS=
#SMTP_FROM=
# Copy this file to .env and fill the values. Do NOT commit the real keys.

DATABASE_URL="postgresql://user:password@localhost:5432/DBname"
JWT_SECRET="replace_with_secret"
REFRESH_TOKEN_SECRET="replace_with_secret"
API_URL=http://localhost:4000

STRIPE_PUBLIC_KEY=pk_test_replace
VITE_STRIPE_PUBLISHABLE=pk_test_replace
STRIPE_SECRET_KEY=sk_test_replace

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=replace_me
SMTP_FROM="Frimousse <no-reply@example.com>"
SMTP_SECURE=false

FRONTEND_URL=http://localhost:5173

INVITE_TOKEN_SECRET=replace_me

PRICE_ID_ESSENTIEL=price_replace
PRICE_ID_PRO=price_replace
PRICE_ID_DECOUVERTE=price_replace

STRIPE_WEBHOOK_SECRET=whsec_replace

# Supabase storage configuration
SUPABASE_URL=https://YOUR_SUPABASE_PROJECT.supabase.co
# SERVICE_ROLE_KEY must be kept secret and only stored on the server
SUPABASE_SERVICE_ROLE_KEY=super_secret_service_role_key
SUPABASE_BUCKET=feed-media
